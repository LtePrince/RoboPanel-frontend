# Copy to .env. These are baseline defaults; the Settings page overrides them at
# runtime (stored in browser localStorage).

# Real robot backend (RoboPanel-backend Go API), full /api/v1 prefix.
VITE_REAL_API_URL=http://localhost:8088/api/v1

# Sim backend (RoboPanel-Simbackend, local LIBERO), full /api/v1 prefix.
VITE_SIM_API_URL=http://localhost:9000/api/v1

# Simulation video directory (local filesystem path, read by the dev server).
# Default: FastWAM evaluation results.
VITE_SIM_VIDEO_BASE=/home/ziyaowang/Alvin/WAM/FastWAM/evaluate_results
